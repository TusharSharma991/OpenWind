{
  "name": "@platform/db",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "db:migrate": "tsx src/run-migrations.ts",
    "db:migrate:create": "drizzle-kit generate",
    "db:seed": "tsx src/seed.ts",
    "db:studio": "drizzle-kit studio",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@platform/config": "workspace:*",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.0"
  },
  "devDependencies": {
    "@platform/tsconfig": "workspace:*",
    "@types/node": "^25.7.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0"
  }
}
