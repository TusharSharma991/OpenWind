NODE_ENV=development

# ── Database ───────────────────────────────────────────────────────────────────
# Connect via PgBouncer (port 6432), not Postgres directly (port 5432).
# PgBouncer uses transaction mode, which is required for SET LOCAL RLS scoping.
# Fixed UUID for the dev tenant — all authenticated users are scoped to this tenant in development.
# Matches the tenant inserted by db:seed. Do not change unless you wipe and re-seed.
DEV_TENANT_ID=00000000-0000-0000-0000-000000000001

DATABASE_URL=postgresql://app_user:app_user_dev_password@localhost:6432/platform
# Migrations must run as the superuser (CREATE SCHEMA requires it).
# Points directly to Postgres (port 5432), bypassing PgBouncer.
MIGRATION_DATABASE_URL=postgresql://migration_user:migration_user_dev_password@localhost:5432/platform
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Base URL config (set these two; everything else is derived) ────────────────
# ZITADEL_URL: the public URL your Zitadel instance is reachable at — by browser
# AND by the backend. All Zitadel endpoints (issuer, JWKS, introspection) derive
# from this. Switching environments = changing this one line.
#   Local dev:   http://localhost:10405  (or http://localhost:8080 if running standalone)
#   Production:  https://owzitadel.yourcompany.com
ZITADEL_URL=http://localhost:8080

# APP_URL: the URL the frontend (admin-ui / portal) is served from.
# Drives CORS_ORIGIN on the backend and API_URL in the browser bundle.
#   Local dev:   http://localhost:3001
#   Production:  https://openwind.yourcompany.com
APP_URL=http://localhost:3001

# ── Auth (Zitadel) ─────────────────────────────────────────────────────────────
# These are derived from ZITADEL_URL automatically if not set explicitly.
# You only need to set them if your Zitadel endpoints differ from the standard paths.
ZITADEL_AUDIENCE=platform-api
ZITADEL_INTROSPECTION_CLIENT_ID=your_introspection_client_id
ZITADEL_INTROSPECTION_CLIENT_SECRET=your_introspection_client_secret
# Service account key for headless M2M auth (JWT Profile Grant / RFC 7523).
# Auto-generated by `pnpm bootstrap` on first run and written to .env.local.
# Value is the base64-encoded JSON key file from Zitadel's management API.
# NEVER commit this value — .env.local is gitignored.
ZITADEL_KEY_JSON=

# ── Notifications (Novu) ───────────────────────────────────────────────────────
NOVU_API_KEY=your_novu_api_key_here

# ── File storage (MinIO / S3) ──────────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=platform-files
S3_ACCESS_KEY=platform_access_key
S3_SECRET_KEY=platform_secret_key_dev_only

# ── Docker Compose overrides (optional) ───────────────────────────────────────
# Override host-port mappings when the defaults conflict with other services.
# These are consumed by docker-compose.yml via ${VAR:-default} syntax.
# Leave unset for standard local dev (uses the default ports shown).
#
# POSTGRES_HOST_PORT=5432     # host port for direct Postgres access (default: 5432)
# ADMIN_UI_HOST_PORT=3001     # host port for Vite dev server (default: 3001)
#
# ── Vite dev server (server deployments only) ──────────────────────────────────
# VITE_ALLOWED_HOSTS=openwind.yourcompany.com  # comma-separated; omit for local dev
# VITE_API_PROXY_TARGET=http://ow-backend:3000 # proxy /api to this URL; omit for local dev

# ── AI (Anthropic) ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Secrets (OpenBao) ──────────────────────────────────────────────────────────
# OpenBao UI: http://localhost:8200
OPENBAO_ADDR=http://localhost:8200
OPENBAO_TRANSIT_KEY=platform-credentials

# Dev: use the static root token (set by docker-compose openbao service).
OPENBAO_TOKEN=dev-root-token

# Production (AppRole): comment out OPENBAO_TOKEN and set these instead.
# OPENBAO_ROLE_ID=
# OPENBAO_SECRET_ID=
