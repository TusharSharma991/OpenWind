# Docker Compose variable defaults — committed, upstream-safe.
# Override any of these in .env.server (gitignored) for hosted deployments.

# Host ports for services exposed to the host
ADMIN_UI_HOST_PORT=3001
ZITADEL_HOST_PORT=8080

# Zitadel external identity — override for hosted deployments
ZITADEL_EXTERNAL_DOMAIN=localhost
ZITADEL_EXTERNALSECURE=false
# ZITADEL_EXTERNAL_PORT defaults to ZITADEL_HOST_PORT in setup.sh (443 for HTTPS behind a proxy)
APP_URL=
