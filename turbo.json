{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "tsconfig.json", "package.json"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "env": [
        "NODE_ENV",
        "DATABASE_URL",
        "DATABASE_POOL_MIN",
        "DATABASE_POOL_MAX",
        "REDIS_URL",
        "ZITADEL_ISSUER",
        "ZITADEL_AUDIENCE",
        "ZITADEL_INTROSPECTION_URL",
        "ZITADEL_INTROSPECTION_CLIENT_ID",
        "ZITADEL_INTROSPECTION_CLIENT_SECRET",
        "NOVU_API_KEY",
        "S3_ENDPOINT",
        "S3_BUCKET",
        "S3_ACCESS_KEY",
        "S3_SECRET_KEY",
        "ANTHROPIC_API_KEY",
        "OPENBAO_ADDR",
        "OPENBAO_TRANSIT_KEY",
        "OPENBAO_TOKEN",
        "OPENBAO_ROLE_ID",
        "OPENBAO_SECRET_ID",
        "ZITADEL_OIDC_CLIENT_ID",
        "ZITADEL_OIDC_CLIENT_SECRET"
      ]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "tsconfig.json"],
      "outputs": []
    },
    "lint": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", ".eslintrc.*", "eslint.config.*"],
      "outputs": []
    },
    "lint:fix": {
      "cache": false
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "tests/**", "vitest.config.*"],
      "outputs": [],
      "env": ["DATABASE_URL", "REDIS_URL", "NODE_ENV"]
    },
    "test:isolation": {
      "dependsOn": ["^build"],
      "inputs": ["tests/isolation/**"],
      "outputs": [],
      "env": ["DATABASE_URL", "NODE_ENV"]
    },
    "test:e2e": {
      "dependsOn": ["^build"],
      "inputs": ["tests/e2e/**"],
      "outputs": [],
      "cache": false,
      "env": ["DATABASE_URL", "REDIS_URL", "API_URL", "NODE_ENV"]
    },
    "db:migrate": {
      "cache": false,
      "env": ["DATABASE_URL"]
    },
    "db:migrate:create": {
      "cache": false
    },
    "db:seed": {
      "cache": false,
      "env": [
        "DATABASE_URL",
        "NODE_ENV",
        "DATABASE_POOL_MIN",
        "DATABASE_POOL_MAX",
        "REDIS_URL",
        "ZITADEL_ISSUER",
        "ZITADEL_AUDIENCE",
        "ZITADEL_INTROSPECTION_URL",
        "ZITADEL_INTROSPECTION_CLIENT_ID",
        "ZITADEL_INTROSPECTION_CLIENT_SECRET",
        "NOVU_API_KEY",
        "S3_ENDPOINT",
        "S3_BUCKET",
        "S3_ACCESS_KEY",
        "S3_SECRET_KEY",
        "ANTHROPIC_API_KEY",
        "OPENBAO_ADDR",
        "OPENBAO_TRANSIT_KEY",
        "OPENBAO_TOKEN",
        "OPENBAO_ROLE_ID",
        "OPENBAO_SECRET_ID"
      ]
    },
    "db:studio": {
      "cache": false,
      "persistent": true,
      "env": ["DATABASE_URL"]
    },
    "clean": {
      "cache": false
    }
  }
}
