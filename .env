# Docker Compose variable defaults.
# Override any of these in .env.local — Docker Compose reads this file first
# for variable interpolation in docker-compose.yml.

# Ports — chosen to avoid common conflicts (3000/3001/8080 are often taken on servers)
ADMIN_UI_HOST_PORT=10404
ZITADEL_HOST_PORT=10405

# Zitadel external domain (override for hosted deployments)
ZITADEL_EXTERNAL_DOMAIN=localhost
