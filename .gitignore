# Dependencies
node_modules/

# Build outputs
dist/
.next/
.cache/
*.tsbuildinfo

# Compiled JS/declarations that may land in src/ on misconfigured builds
packages/*/src/**/*.js
packages/*/src/**/*.js.map
packages/*/src/**/*.d.ts
packages/*/src/**/*.d.ts.map

# Turbo
.turbo/

# Environment — .env is committed (no secrets, just COMPOSE_ENV_FILES pointer)
.env.local
.env.*.local

# Local Docker overrides
docker-compose.override.yml

# Database
*.db
*.sqlite

# Logs
*.log
logs/

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# Claude Code — commit shared config (rules, skills, context, prompts, commands, settings)
# ignore only personal/generated files
.claude/worktrees/
.claude/settings.local.json
.claire/

# Test coverage
coverage/

# pnpm
.pnpm-store/

# Vite
*.local

# Internal team reference (never publish)
INTERNAL.md
INTEGRATION.md
logs.md

# Local tunnel scripts
db-bridge.bat

# Env profiles — prod.env has real credentials, never commit it
envs/prod.env

# Local env switching script (Windows only, not cross-platform)
switch-env.bat
