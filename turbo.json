{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "tsconfig.json", "package.json"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "tsconfig.json"],
      "outputs": []
    },
    "lint": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", ".eslintrc.*", "eslint.config.*"],
      "outputs": []
    },
    "lint:fix": {
      "cache": false
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "tests/**", "vitest.config.*"],
      "outputs": ["coverage/**"],
      "env": ["DATABASE_URL", "REDIS_URL", "NODE_ENV"]
    },
    "test:isolation": {
      "dependsOn": ["^build"],
      "inputs": ["tests/isolation/**"],
      "outputs": [],
      "env": ["DATABASE_URL", "NODE_ENV"]
    },
    "test:e2e": {
      "dependsOn": ["^build"],
      "inputs": ["tests/e2e/**"],
      "outputs": [],
      "cache": false,
      "env": ["DATABASE_URL", "REDIS_URL", "API_URL", "NODE_ENV"]
    },
    "db:migrate": {
      "cache": false,
      "env": ["DATABASE_URL"]
    },
    "db:migrate:create": {
      "cache": false
    },
    "db:seed": {
      "cache": false,
      "env": ["DATABASE_URL", "NODE_ENV"]
    },
    "db:studio": {
      "cache": false,
      "persistent": true,
      "env": ["DATABASE_URL"]
    },
    "clean": {
      "cache": false
    }
  }
}
