{
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git show*)",
      "Bash(pnpm typecheck*)",
      "Bash(pnpm lint*)",
      "Bash(pnpm test*)",
      "Bash(pnpm build*)",
      "Bash(docker compose ps*)",
      "Bash(docker compose logs*)",
      "Bash(find . *)",
      "Bash(ls*)",
      "Bash(wc -l*)",
      "Bash(grep*)",
      "Bash(npx tsx scripts/check-docker-services.ts*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"var cp=require('child_process'),f=process.env.CLAUDE_TOOL_INPUT_FILE_PATH||'';if(f.match(/\\.tsx?$/)){var r=cp.spawnSync('npx',['eslint','--max-warnings=0',f],{encoding:'utf8'});process.stdout.write((r.stdout||'').split('\\n').slice(-8).join('\\n'));}\""
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"var f=process.env.CLAUDE_TOOL_INPUT_FILE_PATH||'';if(f.includes('/migrations/')&&f.endsWith('.sql'))console.log('\\u26a0\\ufe0f  New migration: add isolation tests in tests/isolation/ for any new tenant-scoped tables.');\""
          }
        ]
      }
    ]
  }
}
