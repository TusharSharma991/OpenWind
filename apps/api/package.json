{
  "name": "@platform/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:isolation": "vitest run tests/isolation --passWithNoTests",
    "test:e2e": "vitest run tests/e2e --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "@hono/zod-validator": "^0.4.0",
    "@platform/auth": "workspace:*",
    "@platform/automation-engine": "workspace:*",
    "@platform/config": "workspace:*",
    "@platform/db": "workspace:*",
    "@platform/entity-engine": "workspace:*",
    "@platform/logger": "workspace:*",
    "@platform/redis": "workspace:*",
    "@platform/secrets": "workspace:*",
    "@platform/audit": "workspace:*",
    "@platform/files": "workspace:*",
    "@platform/notifications": "workspace:*",
    "@platform/workflow-engine": "workspace:*",
    "bullmq": "^5.0.0",
    "hono": "^4.5.0",
    "jose": "^5.0.0",
    "ioredis": "^5.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@platform/tsconfig": "workspace:*",
    "@types/node": "^25.7.0",
    "drizzle-orm": "^0.45.2",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.0"
  }
}
